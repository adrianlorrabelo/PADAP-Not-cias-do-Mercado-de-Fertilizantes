# Copie este arquivo para .env.local (uso local com `vercel dev`) e preencha
# com os valores do seu projeto Supabase (Project Settings > API).
# Em produção, configure estas mesmas variáveis no dashboard da Vercel
# (Project Settings > Environment Variables) — nunca commite valores reais.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Segredo gerado por você (ex: um UUID aleatório) para proteger o endpoint
# de cron. A Vercel injeta automaticamente "Authorization: Bearer $CRON_SECRET"
# nas chamadas agendadas quando essa variável está configurada no projeto.
CRON_SECRET=

# Chave de API da Anthropic (console.anthropic.com), usada por /api/summarize
# para gerar o resumo executivo do período selecionado.
ANTHROPIC_API_KEY=
